[Unit]
Description=TrazOp Gunicorn service
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/help_app
EnvironmentFile=/etc/help-app.env
ExecStart=/opt/help_app/.venv/bin/gunicorn --workers 1 --threads 4 --timeout 120 --bind 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
